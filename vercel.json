{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "/api/router"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/router.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/health.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=tomtom,waze,opendata",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=scanner,enrich",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=qualify,notify,enrich-trigger,cascade,cross-exam,claude-reason,backfill-nameless",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=auto-assign,correlate",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=news,news-rss,reddit,people-search,social-search,twilio-lookup",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=pd-press,obituaries,police-social,family-tree,obit-backfill",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=trauma",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=state-crash,tcpa-refresh,relatives-search",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=court,vehicle-history,court-reverse-link",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=audit,errors-clean",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=digest",
      "schedule": "0 9 * * *"
    }
  ]
}