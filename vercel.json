{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/v1/ingest/news.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/ingest/news-rss.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/ingest/court.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/ingest/scanner.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/ingest/obituaries.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/ingest/trauma.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/ingest/reddit.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/ingest/police-social.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/enrich/people-search.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/enrich/trigger.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/system/smoke-test.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/v1/ingest/pd-press.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/v1/cron/dispatch.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=tomtom,waze,opendata",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=scanner,enrich",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=qualify,notify,enrich-trigger",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=auto-assign,correlate",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=news,news-rss,reddit,people-search",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=pd-press,obituaries",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=trauma",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=state-crash",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=court",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=audit,errors-clean",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=digest",
      "schedule": "0 9 * * *"
    }
  ]
}