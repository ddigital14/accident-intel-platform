{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "/api/router"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/router.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/health.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "crons": [
    {"path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=vacuum-nightly", "schedule": "0 4 * * *"},
    
    {"path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=refresh-mv,predictive-at-source,cei-poll", "schedule": "* * * * *"},
    {"path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=pulsepoint,realtime-feed-tick", "schedule": "* * * * *"},
    
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=tomtom,waze,opendata",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=scanner,enrich,transcription-drain",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=qualify,notify,enrich-trigger,cascade,cross-exam,claude-reason,backfill-nameless,smart-router,constant-cross-loop,ensemble-qualifier,contradiction-detector,bidirectional-cascade,saved-alerts,engagement-score,predictive-at-source,refresh-mv",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=auto-assign,correlate,nominatim,pulsepoint,telegram-police",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=news,news-rss,reddit,people-search,social-search,twilio-lookup,address-to-residents,fcc-carrier,dev-profiles,usps-validate,name-rarity,gofundme,funeral-homes,nextdoor",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=pd-press,obituaries,police-social,family-tree,obit-backfill,pdl-by-name,identity-investigator,homegrown-rotation,reddit-history,archive-search,state-courts,business-registry,fl-county-courts,youtube-comments,crm-export,hospital-rss",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=trauma",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=state-crash,tcpa-refresh,relatives-search,co-residence,vehicle-owner,person-merge,temporal-corroborate,confidence-decay,active-learning,salvage-listings,insurance-doi,workers-comp,fatal-family-tree,fraud-filter",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=court,vehicle-history,court-reverse-link,trestle-probe,census-income,attorney-heatmap,lead-stale-recycler,whois-llc",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=audit,errors-clean",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=digest",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/v1/cron/dispatch?secret=ingest-now&jobs=master-lead-list",
      "schedule": "0 12 * * *"
    }
  ]
}