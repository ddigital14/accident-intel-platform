# ============================================================================
# ACCIDENT INTEL PLATFORM - Environment Configuration
# Copy to .env and fill in your values
# ============================================================================

# Server
NODE_ENV=production
PORT=3001
API_PREFIX=/api/v1
JWT_SECRET=your-secure-jwt-secret-here

# Database
DATABASE_URL=postgresql://aip_user:your_password@localhost:5432/accident_intel
DB_HOST=localhost
DB_PORT=5432
DB_NAME=accident_intel
DB_USER=aip_user
DB_PASSWORD=your_password
DB_SSL=false

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# ============================================================================
# DATA SOURCE API KEYS
# ============================================================================

# --- Police / Crash Reports ---
# LexisNexis Accurint (police reports, person lookup, skip tracing)
LEXISNEXIS_API_KEY=
LEXISNEXIS_API_SECRET=
LEXISNEXIS_ENVIRONMENT=production

# CrashDocs / BuyCrash (police crash reports)
CRASHDOCS_API_KEY=
CRASHDOCS_PARTNER_ID=

# Carfax Crash Report API
CARFAX_API_KEY=

# --- Scanner / Dispatch ---
# Broadcastify (police/fire/EMS scanner feeds)
BROADCASTIFY_API_KEY=
BROADCASTIFY_USERNAME=
BROADCASTIFY_PASSWORD=

# OpenMHz (open source scanner feeds)
OPENMHZ_API_KEY=

# PulsePoint (real-time fire/EMS dispatch)
PULSEPOINT_API_KEY=

# RapidSOS (911 data platform)
RAPIDSOS_CLIENT_ID=
RAPIDSOS_CLIENT_SECRET=

# --- CAD / Dispatch Feeds ---
# Tyler Technologies / New World CAD
TYLER_CAD_API_KEY=
TYLER_CAD_ENDPOINT=

# Hexagon Safety CAD
HEXAGON_API_KEY=
HEXAGON_ENDPOINT=

# HigherGround (911 recordings)
HIGHERGROUND_API_KEY=

# --- Hospital / EMS Data ---
# ESO (EMS data platform)
ESO_API_KEY=
ESO_AGENCY_ID=

# ImageTrend (EMS/hospital reporting)
IMAGETREND_API_KEY=
IMAGETREND_SITE_ID=

# NEMSIS (National EMS Information System)
NEMSIS_API_KEY=

# --- Insurance Verification ---
# Verisk / ISO ClaimSearch
VERISK_API_KEY=
VERISK_CUSTOMER_ID=

# TransUnion TLOxp (skip tracing + insurance)
TLO_USERNAME=
TLO_PASSWORD=
TLO_COMPANY_ID=

# LexisNexis Claims (insurance claim search)
LN_CLAIMS_API_KEY=

# --- News & Public Records ---
# NewsAPI
NEWSAPI_KEY=

# Google News API
GOOGLE_NEWS_API_KEY=

# BING News Search
BING_NEWS_API_KEY=

# --- Enrichment ---
# OpenAI (for AI analysis and summarization)
OPENAI_API_KEY=

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- DOT / Government ---
# NHTSA (National Highway Traffic Safety Administration)
NHTSA_API_KEY=

# FMCSA (Federal Motor Carrier Safety Administration - truck/commercial)
FMCSA_API_KEY=

# --- Social Media Monitoring ---
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Geocoding ---
GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=

# --- Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=alerts@yourfirm.com
